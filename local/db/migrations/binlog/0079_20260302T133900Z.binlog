-- dbmig: kategoriya-d-d1 content + seo meta synchronization
SET NAMES utf8mb4;

SET @section_id := (
  SELECT ID
  FROM b_iblock_section
  WHERE IBLOCK_ID = 5
    AND CODE = 'kategoriya-d-d1' COLLATE utf8mb4_unicode_ci
  LIMIT 1
);

SET @uf_text := CONVERT(FROM_BASE64('') USING utf8mb4);

INSERT INTO b_uts_iblock_5_section
  (VALUE_ID, UF_TEXT)
SELECT @section_id, @uf_text
FROM DUAL
WHERE @section_id IS NOT NULL
  AND NOT EXISTS (
    SELECT 1
    FROM b_uts_iblock_5_section
    WHERE VALUE_ID = @section_id
  );

UPDATE b_uts_iblock_5_section
SET UF_TEXT = @uf_text
WHERE VALUE_ID = @section_id;

SET @meta_title := 'Обучение на права категории Д в Воронеже по отличной стоимости: сдать экзамены и открыть водительское удостоверение D для автобуса по доступной цене - отучитесь на курсах для водителей и получите ВУ в автошколе «Форсаж»';
SET @meta_description := 'Сдайте на права категории Д в Воронеже - пройдите обучение для водителей по выгодной стоимости: получение ВУ для вождения автобуса - откройте водительское удостоверение D по оптимальной цене на курсах в автошколе «Форсаж».';

UPDATE b_iblock_iproperty
SET TEMPLATE = @meta_title
WHERE IBLOCK_ID = 5
  AND ENTITY_TYPE = 'S'
  AND ENTITY_ID = @section_id
  AND CODE = 'SECTION_META_TITLE';

INSERT INTO b_iblock_iproperty (IBLOCK_ID, CODE, ENTITY_TYPE, ENTITY_ID, TEMPLATE)
SELECT 5, 'SECTION_META_TITLE', 'S', @section_id, @meta_title
FROM DUAL
WHERE @section_id IS NOT NULL
  AND NOT EXISTS (
    SELECT 1
    FROM b_iblock_iproperty
    WHERE IBLOCK_ID = 5
      AND ENTITY_TYPE = 'S'
      AND ENTITY_ID = @section_id
      AND CODE = 'SECTION_META_TITLE'
  );

UPDATE b_iblock_iproperty
SET TEMPLATE = @meta_description
WHERE IBLOCK_ID = 5
  AND ENTITY_TYPE = 'S'
  AND ENTITY_ID = @section_id
  AND CODE = 'SECTION_META_DESCRIPTION';

INSERT INTO b_iblock_iproperty (IBLOCK_ID, CODE, ENTITY_TYPE, ENTITY_ID, TEMPLATE)
SELECT 5, 'SECTION_META_DESCRIPTION', 'S', @section_id, @meta_description
FROM DUAL
WHERE @section_id IS NOT NULL
  AND NOT EXISTS (
    SELECT 1
    FROM b_iblock_iproperty
    WHERE IBLOCK_ID = 5
      AND ENTITY_TYPE = 'S'
      AND ENTITY_ID = @section_id
      AND CODE = 'SECTION_META_DESCRIPTION'
  );

DELETE FROM b_iblock_section_iprop
WHERE SECTION_ID = @section_id;

UPDATE b_iblock_section
SET TIMESTAMP_X = NOW()
WHERE ID = @section_id;
