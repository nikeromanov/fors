UPDATE b_iblock_element SET `MODIFIED_BY` = 1, `ACTIVE` = 'Y', `ACTIVE_FROM` = NULL, `ACTIVE_TO` = NULL, `SORT` = 500, `NAME` = 'Весеннее предложение на обучение вождению', `PREVIEW_TEXT` = '<p><strong>Скидка 15%</strong> на обучение категории B при записи до конца месяца. Подберите удобный график занятий, начните теорию онлайн и забронируйте место в ближайшей группе без лишних визитов в офис.</p>', `PREVIEW_TEXT_TYPE` = 'html', `DETAIL_TEXT` = '<p>Предложение подходит тем, кто хочет быстро стартовать обучение и заранее зафиксировать выгодную стоимость. В программу входят теория, практика с инструктором, сопровождение до экзамена и помощь с подготовкой документов.</p><p>Оставьте заявку, и менеджер подберет филиал, график занятий и ближайшую дату старта группы.</p>', `DETAIL_TEXT_TYPE` = 'html', `SEARCHABLE_CONTENT` = 'ВЕСЕННЕЕ ПРЕДЛОЖЕНИЕ НА ОБУЧЕНИЕ ВОЖДЕНИЮ\r\nСКИДКА 15% НА ОБУЧЕНИЕ КАТЕГОРИИ B ПРИ ЗАПИСИ \r\nДО КОНЦА МЕСЯЦА. ПОДБЕРИТЕ УДОБНЫЙ ГРАФИК ЗАНЯТИЙ, НАЧНИТЕ ТЕОРИЮ ОНЛАЙН И ЗАБРОНИРУЙТЕ МЕСТО В БЛИЖАЙШЕЙ ГРУППЕ БЕЗ ЛИШНИХ ВИЗИТОВ В ОФИС.\r\nПРЕДЛОЖЕНИЕ ПОДХОДИТ ТЕМ, КТО ХОЧЕТ БЫСТРО \r\nСТАРТОВАТЬ ОБУЧЕНИЕ И ЗАРАНЕЕ ЗАФИКСИРОВАТЬ ВЫГОДНУЮ СТОИМОСТЬ. В ПРОГРАММУ ВХОДЯТ ТЕОРИЯ, ПРАКТИКА С ИНСТРУКТОРОМ, СОПРОВОЖДЕНИЕ ДО ЭКЗАМЕНА И ПОМОЩЬ С ПОДГОТОВКОЙ ДОКУМЕНТОВ.\r\n\r\nОСТАВЬТЕ ЗАЯВКУ, И МЕНЕДЖЕР ПОДБЕРЕТ ФИЛИАЛ, \r\nГРАФИК ЗАНЯТИЙ И БЛИЖАЙШУЮ ДАТУ СТАРТА ГРУППЫ.', `CODE` = 'promo', `TAGS` = '', `TMP_ID` = '0', TIMESTAMP_X=now() WHERE ID=2002
/*!*/;
