-- dbmig: kategoriya-a content cleanup + seo meta synchronization
SET NAMES utf8mb4;

SET @section_id := (
  SELECT ID
  FROM b_iblock_section
  WHERE IBLOCK_ID = 5
    AND CODE = 'kategoriya-a' COLLATE utf8mb4_unicode_ci
  LIMIT 1
);

SET @description_html := CONVERT(FROM_BASE64('') USING utf8mb4);
SET @uf_text := CONVERT(FROM_BASE64('') USING utf8mb4);

UPDATE b_iblock_section
SET DESCRIPTION = @description_html,
    DESCRIPTION_TYPE = 'html'
WHERE ID = @section_id;

INSERT INTO b_uts_iblock_5_section
  (VALUE_ID, UF_TEXT)
SELECT @section_id, @uf_text
FROM DUAL
WHERE @section_id IS NOT NULL
  AND NOT EXISTS (
    SELECT 1
    FROM b_uts_iblock_5_section
    WHERE VALUE_ID = @section_id
  );

UPDATE b_uts_iblock_5_section
SET UF_TEXT = @uf_text
WHERE VALUE_ID = @section_id;

SET @meta_title := 'Обучение категории А в Воронеже – отучиться на права по доступной стоимости: вождение мотоцикла для получения водительского удостоверения – сдать экзамен и открыть направление ВУ по отличной цене с автошколой «Форсаж»';
SET @meta_description := 'Пройдите обучение на права категории А в Воронеже по привлекательной стоимости: освойте езду на мотоцикле для сдачи экзамена и получите водительское удостоверение – отучитесь по оптимальной цене на курсах вождения от автошколы «Форсаж».';

UPDATE b_iblock_iproperty
SET TEMPLATE = @meta_title
WHERE IBLOCK_ID = 5
  AND ENTITY_TYPE = 'S'
  AND ENTITY_ID = @section_id
  AND CODE = 'SECTION_META_TITLE';

INSERT INTO b_iblock_iproperty (IBLOCK_ID, CODE, ENTITY_TYPE, ENTITY_ID, TEMPLATE)
SELECT 5, 'SECTION_META_TITLE', 'S', @section_id, @meta_title
FROM DUAL
WHERE @section_id IS NOT NULL
  AND NOT EXISTS (
    SELECT 1
    FROM b_iblock_iproperty
    WHERE IBLOCK_ID = 5
      AND ENTITY_TYPE = 'S'
      AND ENTITY_ID = @section_id
      AND CODE = 'SECTION_META_TITLE'
  );

UPDATE b_iblock_iproperty
SET TEMPLATE = @meta_description
WHERE IBLOCK_ID = 5
  AND ENTITY_TYPE = 'S'
  AND ENTITY_ID = @section_id
  AND CODE = 'SECTION_META_DESCRIPTION';

INSERT INTO b_iblock_iproperty (IBLOCK_ID, CODE, ENTITY_TYPE, ENTITY_ID, TEMPLATE)
SELECT 5, 'SECTION_META_DESCRIPTION', 'S', @section_id, @meta_description
FROM DUAL
WHERE @section_id IS NOT NULL
  AND NOT EXISTS (
    SELECT 1
    FROM b_iblock_iproperty
    WHERE IBLOCK_ID = 5
      AND ENTITY_TYPE = 'S'
      AND ENTITY_ID = @section_id
      AND CODE = 'SECTION_META_DESCRIPTION'
  );

DELETE FROM b_iblock_section_iprop
WHERE SECTION_ID = @section_id;

UPDATE b_iblock_section
SET TIMESTAMP_X = NOW()
WHERE ID = @section_id;
